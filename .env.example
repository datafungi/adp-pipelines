# Copy to .env (gitignored) and fill in. Consumed by docker-compose for local Airflow
# and by tests/plugins that hit real services (`pytest -m integration`).

# --- Azure Key Vault secrets backend (REQUIRED for docker-compose) ---
# The dedicated local-dev service principal, granted "Key Vault Secrets User" on
# kv-adp-dev-sea (object id e6c7d49c-8e76-4fd1-b58d-756630018240). Airflow's secrets
# backend reads Connections/Variables from the vault as this SP (EnvironmentCredential).
KV_CLIENT_ID=<local-dev SP application (client) id>
KV_CLIENT_SECRET=<local-dev SP client secret>
KV_NAME=kv-adp-dev-sea
KV_URI=https://kv-adp-dev-sea.vault.azure.net/
# Tenant defaults to the ADP directory in docker-compose; override here only if needed.
# AZURE_TENANT_ID=333f776e-0027-4602-960c-8360621b775c

# --- SharePoint (only if your DAGs/tests hit SharePoint) ---
SHAREPOINT_TENANT_ID=<tenant id>
SHAREPOINT_CLIENT_ID=<app client id>
SHAREPOINT_CLIENT_SECRET=<app client secret>
SHAREPOINT_TEST_SITE_URL=<https://contoso.sharepoint.com/sites/...>

# --- docker-compose local runtime ---
# Run Airflow as your host user so bind-mounted ./logs isn't written root-owned.
# Set to your uid:  echo "AIRFLOW_UID=$(id -u)" >> .env
AIRFLOW_UID=50000
# Break-glass admin created by `docker compose up airflow-init` (local only).
# _AIRFLOW_WWW_USER_USERNAME=admin
# _AIRFLOW_WWW_USER_PASSWORD=admin
# Pull a specific CI-built image instead of building locally (used without --build).
# AIRFLOW_IMAGE_TAG=dev
